# OpenAI
OPENAI_API_KEY=sk-proj-...

# Database
DATABASE_URL=sqlite+aiosqlite:///./storage/planwrite.db

# Offers (BAM)
OFFERS_PROPERTY=action_network

# Odds (Charlotte/RotoGrinders)
ODDS_API_KEY=

# BC Core (public API by default when BC_CORE_API_KEY is set)
BC_CORE_BASE_URL=https://core-platform-api.actionnetwork.com
BC_CORE_API_KEY=

# Optional legacy tunnel/proxy path via Tailscale/Hetzner
BC_CORE_SOCKS_PROXY=
BC_CORE_PROXY_BEARER=
BC_CORE_TIMEOUT_SECONDS=60
TS_AUTHKEY=
TS_HOSTNAME=planwrite-railway

# App settings
DEBUG=true
SECRET_KEY=change-me-in-production

# Authentication
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
AUTH_SESSION_SECRET=change-session-secret
# Optional multi-user auth (JSON object). If set, this overrides AUTH_USERNAME/AUTH_PASSWORD.
# Example: AUTH_USERS_JSON={"admin":"strongpass1","usteam":"strongpass2"}
AUTH_USERS_JSON=

# RAG settings
EMBED_MODEL=text-embedding-3-small
LLM_MODEL=gpt-5.2-2025-12-11
