# /etc/bc-proxy/env  (chmod 600, owned by root)

# The real BC Core API key. The proxy injects this on every forwarded request,
# so clients (planwrite-v2 on Railway) never see it.
BC_CORE_API_KEY=replace-with-the-prod-bc-core-key

# Optional overrides
# BC_CORE_UPSTREAM=core-external-api.actionnetwork.com
# BC_CORE_TIMEOUT_SECONDS=30
